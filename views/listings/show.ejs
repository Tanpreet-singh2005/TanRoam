<% layout("/layouts/boilerplate") %>

<div class="row">
  <div class="col-8 offset-3">
    <h3><%= listing.title %></h3>

    <div class="listing-card" style="width: 18rem;">
      <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="Place Image">

      <div class="card-body">
        <p class="card-text">
          Owned by <i><%= listing.owner.username %></i>
        </p>
        <p class="card-text"><%= listing.description %></p>
        <p class="card-text">
          &#x20B9;<%= listing.price ? listing.price.toLocaleString("en-IN") : "Not specified" %>
        </p>
        <p class="card-text"><%= listing.location %></p>
        <p class="card-text"><%= listing.country %></p>
      </div>
    </div>

    <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-dark mt-2">
        Edit this Listing
      </a>

      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="mt-2">
        <button class="btn btn-danger">Delete</button>
      </form>
    <% } %>
  </div>
</div>

<!-- REVIEW FORM -->
<% if (currUser) { %>
<div class="row mt-4">
  <div class="col-8 offset-3">
    <hr>
    <h4>Leave a Review</h4>

    <form method="POST" action="/listings/<%= listing._id %>/reviews" class="needs-validation" novalidate>

      <!-- STAR RATING -->
      <fieldset class="starability-slot mb-3">
        <legend>Rating</legend>
         <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
        <input type="radio" id="rate1" name="review[rating]" value="1" />
        <label for="rate1">1 star</label>

        <input type="radio" id="rate2" name="review[rating]" value="2" />
        <label for="rate2">2 stars</label>

        <input type="radio" id="rate3" name="review[rating]" value="3" />
        <label for="rate3">3 stars</label>

        <input type="radio" id="rate4" name="review[rating]" value="4" />
        <label for="rate4">4 stars</label>

        <input type="radio" id="rate5" name="review[rating]" value="5" />
        <label for="rate5">5 stars</label>
      </fieldset>

      <!-- COMMENT -->
      <div class="mb-3">
        <label for="comment" class="form-label">Comments</label>
        <textarea
          name="review[comment]"
          id="comment"
          rows="5"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">
          Please add a comment
        </div>
      </div>

      <button class="btn btn-danger">Submit</button>
    </form>
  </div>
</div>
<% } %>

<!-- ALL REVIEWS -->
<div class="row mt-4">
  <div class="col-8 offset-3">
    <hr>
    <h4>All Reviews</h4>

    <div class="row">
      <% for (let review of listing.reviews) { %>
        <div class="card col-5 ms-3 mb-3">
          <div class="card-body">
            <h5 class="card-title">@<%= review.author.username %></h5>
            <p class="card-text"><%= review.comment %></p>

            <!-- STAR DISPLAY -->
            <p class="starability-result" data-rating="<%= review.rating %>">
              Rated <%= review.rating %> stars
            </p>
          </div>

          <% if (currUser && currUser._id.equals(review.author._id)) { %>
            <form
              method="POST"
              action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
              class="ms-3 mb-3"
            >
              <button class="btn btn-danger btn-sm">Delete</button>
            </form>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</div>
